---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	/** 隱藏頁尾（如閱讀密室可選） */
	hideFooter?: boolean;
	/** 額外 body class */
	bodyClass?: string;
}

const { title, description, image, hideFooter = false, bodyClass = '' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body class:list={['flex min-h-screen flex-col', bodyClass]}>
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		{!hideFooter && <Footer />}
	</body>
</html>
