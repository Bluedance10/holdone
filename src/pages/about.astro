---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ABOUT_STORY, BOOKING_COPY, SITE_ROLE } from '../consts';
---

<BaseLayout
	title={ABOUT_STORY.title}
	description="從嚴重貧血、長期低潮與憂鬱，到心臟驟停——抱元守一主理人的真實故事。"
>
	<section class="page-shell py-16 md:py-24">
		<div class="mx-auto max-w-3xl text-center">
			<p class="section-label animate-fade-rise">真實</p>
			<h1 class="font-lishu animate-fade-rise animate-delay-1">{ABOUT_STORY.title}</h1>
			<div class="ink-divider" aria-hidden="true"><span></span></div>
		</div>

		<div class="mx-auto mt-2 max-w-2xl space-y-8">
			<p class="text-center text-lg tracking-[0.12em] text-ink-faint md:text-xl font-heiti">
				{ABOUT_STORY.leadLines[0]}
				<br />
				{ABOUT_STORY.leadLines[1]}
			</p>
			{
				ABOUT_STORY.paragraphs.slice(1).map((p) => (
					<p class="text-base leading-relaxed tracking-[0.04em] text-ink-soft font-heiti md:text-lg md:leading-[2]">
						{p.includes('自主權') ? (
							p.split(/(自主權。?)/g).map((part) =>
								part.startsWith('自主權') ? (
									<span class="whitespace-nowrap">{part}</span>
								) : (
									part
								),
							)
						) : (
							p
						)}
					</p>
				))
			}

			<div class="paper-card mt-6 px-8 py-10 text-center">
				<p class="font-lishu !text-lg !tracking-[0.18em] text-ink">{SITE_ROLE}</p>
				<p class="mt-4 text-base tracking-[0.04em] text-ink-mute font-heiti">
					找自己 → 救自己 → 養自己 → 愛自己
				</p>
			</div>
		</div>
	</section>

	<section class="border-t border-paper-edge/45 bg-blush-soft/20">
		<div class="page-shell py-16 text-center md:py-20">
			<p class="section-label">下一步</p>
			<h2 class="font-lishu">核心理念</h2>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a href="/philosophy" class="btn-ghost">閱讀理念</a>
				<a href={BOOKING_COPY.href} class="btn-ritual">{BOOKING_COPY.cta}</a>
			</div>
		</div>
	</section>
</BaseLayout>
