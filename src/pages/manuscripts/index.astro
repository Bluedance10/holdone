---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BOOKING_COPY } from '../../consts';
---

<BaseLayout
	title="生命手稿分享"
	description="抱元守一生命手稿分享——敬請期待。"
>
	<section class="page-shell py-16 md:py-28">
		<div class="mx-auto max-w-3xl text-center">
			<p class="section-label animate-fade-rise">實證</p>
			<h1 class="font-lishu animate-fade-rise animate-delay-1">生命手稿分享</h1>
			<div class="ink-divider" aria-hidden="true"><span></span></div>
		</div>

		<div class="mx-auto mt-4 max-w-2xl">
			<div
				class="paper-card relative overflow-hidden px-8 py-20 text-center md:px-14 md:py-24"
				style="background: linear-gradient(160deg, color-mix(in srgb, var(--color-peach-btn) 45%, white), var(--color-paper));"
			>
				<span class="badge-soon">Coming Soon</span>
				<h2 class="font-lishu mt-8 !text-2xl !tracking-[0.28em] text-ink md:!text-3xl">
					敬請期待
				</h2>
				<p class="mx-auto mt-8 max-w-md text-base leading-relaxed tracking-[0.04em] text-ink-mute font-heiti md:text-lg">
					生命手稿分享區塊正在安靜醞釀中。<br />
					完整篇章將於適當時機公開。
				</p>
			</div>
		</div>

		<div class="mt-16 text-center">
			<a href={BOOKING_COPY.href} class="btn-ritual">{BOOKING_COPY.cta}</a>
		</div>
	</section>
</BaseLayout>
