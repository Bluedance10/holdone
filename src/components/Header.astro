---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, SITE_NAME_EN, NAV_LINKS, BOOKING_COPY } from '../consts';
// 導覽 CTA：預約席位
---

<header
	class="sticky top-0 z-50 border-b border-paper-edge/50 bg-paper/88 backdrop-blur-md"
	id="site-header"
>
	<nav class="page-shell flex items-center justify-between gap-3 py-4 md:gap-4 md:py-5" aria-label="主選單">
		<a
			href="/"
			class="nav-brand-link group shrink-0 no-underline hover:no-underline"
			aria-label={`${SITE_TITLE} ${SITE_NAME_EN} 首頁`}
		>
			<span class="nav-brand text-ink transition-colors group-hover:text-peach-deep">
				{SITE_TITLE}
			</span>
			<span class="nav-brand-en transition-colors group-hover:text-gold-deep">
				{SITE_NAME_EN}
			</span>
		</a>

		<ul class="hidden items-center gap-0.5 md:flex lg:gap-1">
			{
				NAV_LINKS.map((link) => (
					<li>
						<HeaderLink
							href={link.href}
							class="px-2.5 py-2 text-[0.95rem] font-medium tracking-[0.16em] text-ink-mute no-underline transition-colors hover:text-peach-deep lg:px-3.5 lg:text-base lg:tracking-[0.18em]"
						>
							{link.label}
						</HeaderLink>
					</li>
				))
			}
		</ul>

		<a href={BOOKING_COPY.href} class="btn-ritual hidden !px-5 !py-2.5 !text-[0.95rem] md:inline-flex">
			{BOOKING_COPY.navCta}
		</a>

		<button
			type="button"
			id="nav-toggle"
			class="flex h-11 w-11 items-center justify-center rounded-full border border-paper-edge text-ink transition-colors hover:border-peach hover:bg-blush-soft/40 hover:text-peach-deep md:hidden"
			aria-expanded="false"
			aria-controls="mobile-nav"
			aria-label="開啟選單"
		>
			<span class="sr-only">選單</span>
			<svg id="icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
				<path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
			</svg>
			<svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
				<path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
			</svg>
		</button>
	</nav>

	<div
		id="mobile-nav"
		class="hidden border-t border-paper-edge/50 bg-paper/96 backdrop-blur-md md:hidden"
		hidden
	>
		<ul class="page-shell flex flex-col py-3">
			{
				NAV_LINKS.map((link) => (
					<li>
						<HeaderLink
							href={link.href}
							class="block border-b border-paper-edge/35 py-4 text-center text-lg font-medium tracking-[0.24em] text-ink no-underline transition-colors hover:text-peach-deep"
						>
							{link.label}
						</HeaderLink>
					</li>
				))
			}
			<li class="pt-6 pb-3 text-center">
				<a href={BOOKING_COPY.href} class="btn-ritual">{BOOKING_COPY.navCta}</a>
			</li>
		</ul>
	</div>
</header>

<style>
	:global(a.active) {
		color: var(--color-peach-deep) !important;
		position: relative;
	}

	:global(nav a.active)::after {
		content: '';
		position: absolute;
		left: 50%;
		bottom: 0.1rem;
		transform: translateX(-50%);
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--color-peach), var(--color-rose));
	}

	@media (max-width: 767px) {
		:global(#mobile-nav a.active)::after {
			bottom: 0.85rem;
		}
	}
</style>

<script>
	const toggle = document.getElementById('nav-toggle');
	const panel = document.getElementById('mobile-nav');
	const iconOpen = document.getElementById('icon-open');
	const iconClose = document.getElementById('icon-close');

	function setOpen(open: boolean) {
		if (!toggle || !panel || !iconOpen || !iconClose) return;
		toggle.setAttribute('aria-expanded', String(open));
		toggle.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
		panel.hidden = !open;
		panel.classList.toggle('hidden', !open);
		iconOpen.classList.toggle('hidden', open);
		iconClose.classList.toggle('hidden', !open);
		document.body.style.overflow = open ? 'hidden' : '';
	}

	toggle?.addEventListener('click', () => {
		setOpen(toggle.getAttribute('aria-expanded') !== 'true');
	});

	panel?.querySelectorAll('a').forEach((a) => {
		a.addEventListener('click', () => setOpen(false));
	});

	window.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') setOpen(false);
	});
</script>
