---
import {
	SITE_BRAND,
	SITE_TAGLINE_SUB,
	SITE_COPYRIGHT,
	NAV_LINKS,
	FOOTER_LEGAL,
} from '../consts';
---

<footer class="mt-auto border-t border-paper-edge/45">
	<div class="page-shell py-16 md:py-20">
		<div class="flex flex-col items-center text-center">
			<p class="nav-brand text-ink !text-2xl md:!text-[1.75rem]">抱一</p>
<p class="mt-3 max-w-md text-sm tracking-[0.12em] text-ink-mute font-heiti">
擁抱獨一無二的自己
</p>

			<div class="ink-divider my-8" aria-hidden="true">
				<span></span>
			</div>

			<nav aria-label="頁尾導覽">
				<ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
					{
						NAV_LINKS.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-base font-medium tracking-[0.16em] text-ink-mute no-underline transition-colors hover:text-peach-deep"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<nav class="mt-6" aria-label="法律與說明">
				<ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
					{
						FOOTER_LEGAL.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm tracking-[0.12em] text-ink-faint no-underline transition-colors hover:text-gold-deep font-heiti"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<p class="mt-12 max-w-lg text-sm leading-relaxed tracking-[0.06em] text-ink-faint font-heiti">
				{SITE_COPYRIGHT}
			</p>
		</div>
	</div>
</footer>
