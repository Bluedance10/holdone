---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = '/blog-placeholder-1.jpg' } = Astro.props;
const fullTitle =
  title === '抱元守一' || title === '抱一'
    ? '首席人生載體顧問｜載體重啟 · 生活美學 · 頻率對位'
    : `${title} · 抱元守一`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#f9f6f0" />

<!-- 標題 Noto Serif TC · 正文 Noto Sans TC -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@500;600;700&display=swap"
	rel="stylesheet"
/>

<link rel="canonical" href={canonicalURL} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:locale" content="zh_TW" />
<meta property="og:site_name" content="抱元守一" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.url)} />
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://baoyuansoyi.com/#website",
      "url": "https://baoyuansoyi.com",
      "name": "抱元守一",
      "alternateName": ["抱一", "BaoYuanSoYi"],
      "description": "首席人生載體顧問｜載體重啟 · 生活美學 · 頻率對位。透過簡單的調整與練習，邀請您一同探索元氣與自主權。源自個人生命實證，歡迎有緣人前來深度交流。",
      "inLanguage": "zh-Hant",
      "publisher": {
        "@id": "https://baoyuansoyi.com/#organization"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://baoyuansoyi.com/#organization",
      "name": "步鹿丹思創意行銷有限公司",
      "url": "https://baoyuansoyi.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://baoyuansoyi.com/favicon.svg"
      }
    },
    {
      "@type": "Person",
      "@id": "https://baoyuansoyi.com/#person",
      "name": "抱元守一",
      "alternateName": "首席人生載體顧問",
      "jobTitle": "首席人生載體顧問",
      "description": "載體重啟・生活美學・頻率對位。透過個人生命實證，陪伴高敏者與高淨值人士重新找回身體自主權。",
      "url": "https://baoyuansoyi.com",
      "worksFor": {
        "@id": "https://baoyuansoyi.com/#organization"
      }
    }
  ]
}
</script>